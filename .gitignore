__pycache__/
*.py[cod]
*.so
.venv/
venv/
.ipynb_checkpoints/
.DS_Store
# Model weights are kept in-tree (small, ~1.5 MB total) so CI/CD can
# regenerate the audio preview without having to retrain every phase.
# Phase-9's per-(alpha,seed) sweep is the only one we still exclude.
results/phase9_timbre_sweep/**/*.pt

# CI-built preview site
preview/

# Per-round ralph loop artifacts (the only thing that survives is the
# in-tree replacement of results/phase*/<...>.pt when a candidate beats
# the baseline). The rolling per-round candidates would otherwise dirty
# the working tree continuously and trip the stop-hook.
results/ralph_runs/
results/ralph_loop.log
*.egg-info/
.vscode/
